*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# SQLite WAL-mode runtime sidecars — created when a process opens a
# sqlite db with WAL enabled and removed on clean close. Never source.
*.sqlite-shm
*.sqlite-wal
*.sqlite-journal

