# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
!src/**/build/
!benchmarks/build/
!tests/**/build/
!scripts/build/

# Datapack build provenance — regenerated on every build, not read at runtime
# or by verify/release. Noisy churn (esp. on a from-scratch build), so keep it
# out of the repo and the wheel. Runtime essentials (entities.sqlite,
# metadata.json, symspell.dict, *_calibrator.json) stay tracked.
src/resolvekit/_data/**/changelog.md
src/resolvekit/_data/**/diff_*.json
src/resolvekit/_data/**/qa_report.json
src/resolvekit/_data/**/reports/

# Release assets: every byte-bearing file for a remote-distribution module
# (sqlite + symspell.dict + their .gz forms) ships from the GitHub Release, not
# the wheel. The wheel contains only metadata.json for these modules; runtime
# fetches the assets on first use and assembles them into the cache directory.
src/resolvekit/_data/**/*.sqlite.gz
src/resolvekit/_data/**/*.dict.gz
src/resolvekit/_data/geo/admin1/entities.sqlite
src/resolvekit/_data/geo/admin1/symspell.dict
src/resolvekit/_data/geo/admin2/entities.sqlite
src/resolvekit/_data/geo/admin2/symspell.dict
src/resolvekit/_data/geo/admin3/entities.sqlite
src/resolvekit/_data/geo/admin3/symspell.dict
src/resolvekit/_data/geo/admin4/entities.sqlite
src/resolvekit/_data/geo/admin4/symspell.dict
src/resolvekit/_data/geo/admin5/entities.sqlite
src/resolvekit/_data/geo/admin5/symspell.dict
src/resolvekit/_data/geo/cities/entities.sqlite
src/resolvekit/_data/geo/cities/symspell.dict

# Local asset-map for the most recent release_data run — output, not source.
# Regenerated on every release; the wire-format catalogue is
# src/resolvekit/_data/manifest.json (which IS tracked).
/release-manifest.json

develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

